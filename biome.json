{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "files": {
        "includes": ["**"]
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        },
        "includes": ["**", "!**/dist", "!**/node_modules", "!**/.svelte-kit"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "includes": ["**", "!**/dist", "!**/node_modules"]
    },
    "vcs": {
        "enabled": true,
        "useIgnoreFile": true,
        "clientKind": "git"
    },
    "overrides": [
        {
            "includes": ["**/*.svelte", "**/*.astro", "**/*.vue"],
            "linter": {
                "rules": {
                    "style": {
                        "useConst": "off",
                        "useImportType": "off"
                    },
                    "correctness": {
                        "noUnusedVariables": "off",
                        "noUnusedImports": "off"
                    }
                }
            }
        }
    ]
}
