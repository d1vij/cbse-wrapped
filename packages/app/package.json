{
    "name": "@cbse-wrapped/app",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "exports": {
        "./schemas": {
            "import": "./dist/schemas/index.js",
            "types": "./dist/schemas/index.d.js"
        }
    },
    "scripts": {
        "dev": "bun run --bun vite dev",
        "build": "bun run --bun vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "lint": "prettier --check . && eslint . --write",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@cbse-wrapped/data": "workspace:*",
        "@d1vij/shit-i-always-use": "^0.1.26",
        "@leeoniya/ufuzzy": "^1.0.19",
        "@lucide/svelte": "^1.3.0",
        "@types/hyphen": "^1.14.0",
        "hyphen": "^1.14.1",
        "radashi": "^12.9.1",
        "runed": "^0.37.1",
        "valibot": "^1.4.0"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.4",
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.57.0",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.2",
        "@types/bun": "^1.3.14",
        "@types/node": "^24",
        "globals": "^17.4.0",
        "svelte": "^5.55.2",
        "svelte-check": "^4.4.6",
        "tailwindcss": "^4.2.2",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1",
        "vite": "^8.0.7"
    }
}
