default:
    @just --list

# run pytest in tests/ directory
test *args=".":
    #!/usr/bin/env bash
    cd {{invocation_directory()}}
    uv run pytest {{args}}

# format using ruff
format *args="":
    uv run ruff format {{args}}

# lint using ruff
lint *args="":
    uv run ruff check {{args}}

jupyter:
    uv run jupyter-lab --no-browser
