{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        // Environment setup & latest features
        "lib": ["ESNext"],
        "target": "ESNext",
        "module": "Preserve",
        "moduleDetection": "force",
        "types": ["bun"],
        "paths": {
            "~/*": ["./src/*"]
        }
    },
    "include": ["src/**/*", "scripts/**/*"]
}
