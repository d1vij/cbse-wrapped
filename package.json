{
    "name": "cbse-wrapped",
    "version": "0.1.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/d1vij/cbse-wrapped.git"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@types/bun": "^1.3.14",
        "bumpp": "^11.1.0",
        "bunup": "^0.16.31",
        "husky": "^9.1.7",
        "typescript": "^6.0.3",
        "vitest": "^4.1.6"
    },
    "files": [
        "dist"
    ],
    "homepage": "https://github.com/d1vij/cbse-wrapped#readme",
    "license": "MIT",
    "private": true,
    "scripts": {
        "build": "bunup",
        "dev": "bunup --watch",
        "lint": "biome check . --write",
        "format": "biome format --write .",
        "tsc": "tsc --noEmit",
        "test": "bun test",
        "prepare": "husky",
        "orchestrator:scrape": "bun run --filter @cbse-wrapped/orchestrator scrape",
        "orchestrator:compile": "bun run --filter @cbse-wrapped/orchestrator compile"
    },
    "type": "module",
    "types": "./dist/index.d.ts",
    "workspaces": [
        "packages/*"
    ]
}
