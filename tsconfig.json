{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "isolatedDeclarations": false
    },
    // reference
    "references": [
        {
            "path": "./packages/scraper"
        },
        {
            "path": "./packages/data"
        }
    ],
    "exclude": ["node_modules", "dist"]
}
