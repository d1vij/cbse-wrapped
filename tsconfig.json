{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "isolatedDeclarations": false,
        "rootDir": ".",
        "outDir": "./dist"
    },
    "exclude": ["node_modules", "dist"]
}
